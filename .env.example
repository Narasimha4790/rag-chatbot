# Copy this file to '.env' and fill in your details before running the application

# Google Gemini API Key (Obtain for free from Google AI Studio)
GEMINI_API_KEY=your_google_gemini_api_key_here

# ChromaDB Settings (Defaults for local running. Compose sets these automatically inside containers)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=data/chromadb
